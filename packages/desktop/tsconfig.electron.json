{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "electron/dist",
    "rootDir": "electron",
    "noEmit": false
  },
  "include": ["electron/main.ts"]
}
