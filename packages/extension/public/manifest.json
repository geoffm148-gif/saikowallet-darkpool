{
    "manifest_version":  3,
    "name":  "Saiko Wallet",
    "version":  "0.1.10",
    "description":  "Non-custodial Ethereum wallet with DarkPool privacy — powered by Saiko Inu",
    "permissions":  [
                        "storage",
                        "activeTab",
                        "alarms",
                        "offscreen",
                        "windows",
                        "tabs"
                    ],
    "host_permissions":  [
                             "https://*/*"
                         ],
    "background":  {
                       "service_worker":  "background.js",
                       "type":  "module"
                   },
    "action":  {
                   "default_popup":  "popup.html",
                   "default_icon":  {
                                        "128":  "icons/icon128.png"
                                    },
                   "default_title":  "Saiko Wallet"
               },
    "icons":  {
                  "128":  "icons/icon128.png"
              },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://*/*"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_start",
                                "all_frames":  true
                            }
                        ],
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "inpage.js"
                                                       ],
                                         "matches":  [
                                                         "https://*/*"
                                                     ]
                                     }
                                 ],
    "content_security_policy":  {
                                    "extension_pages":  "script-src \u0027self\u0027 \u0027wasm-unsafe-eval\u0027; object-src \u0027self\u0027"
                                }
}
