{
  "expo": {
    "name": "Saiko Wallet",
    "slug": "saiko-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/saiko-logo.png",
    "userInterfaceStyle": "dark",
    "scheme": "saiko-wallet",
    "splash": {
      "image": "./assets/saiko-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saikowallet.app"
    },
    "android": {
      "package": "com.saikowallet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/saiko-logo.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "favicon": "./assets/saiko-logo.png",
      "bundler": "metro",
      "backgroundColor": "#0A0A0A",
      "themeColor": "#0A0A0A"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-barcode-scanner"
    ]
  }
}
